    {"type":"text","id":"ev1_code","x":45,"y":595,"width":500,"height":80,"text":"POST /api/v1/jobs                    → Create job\nPOST /api/v1/schedule/generate       → AI-optimized schedule\nPOST /api/v1/ai/chat                 → Chat with AI agent\nGET  /api/v1/customers?page=1&status → Paginated list\nPOST /api/v1/invoices/{id}/payment   → Record payment","originalText":"POST /api/v1/jobs                    → Create job\nPOST /api/v1/schedule/generate       → AI-optimized schedule\nPOST /api/v1/ai/chat                 → Chat with AI agent\nGET  /api/v1/customers?page=1&status → Paginated list\nPOST /api/v1/invoices/{id}/payment   → Record payment","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#22c55e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":500005,"version":1,"versionNonce":500006,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},

