# =============================================================================
# Grin's Irrigation Platform — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# PostgreSQL connection string (async driver for SQLAlchemy)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/grins_platform

# -----------------------------------------------------------------------------
# Redis (rate limiting, staff location caching)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
SECRET_KEY=your-secret-key-min-32-chars
JWT_SECRET_KEY=your-jwt-secret-min-32-chars
# Optional: previous JWT secret for key rotation (24h grace period)
# JWT_PREVIOUS_SECRET_KEY=

# -----------------------------------------------------------------------------
# AI Features (OpenAI)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=your-openai-api-key

# -----------------------------------------------------------------------------
# Google Maps (travel time calculations)
# -----------------------------------------------------------------------------
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# -----------------------------------------------------------------------------
# Google Sheets Integration
# -----------------------------------------------------------------------------
GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id
GOOGLE_SHEETS_SHEET_NAME=1. Job Requests
GOOGLE_SHEETS_POLL_INTERVAL_SECONDS=60
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./service-account-key.json

# -----------------------------------------------------------------------------
# SMS (Twilio)
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# -----------------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------------
STRIPE_CUSTOMER_PORTAL_URL=https://billing.stripe.com/p/login/test_placeholder

# -----------------------------------------------------------------------------
# S3-Compatible Object Storage (file uploads: photos, attachments, media, PDFs)
# -----------------------------------------------------------------------------
# For local dev with MinIO, set S3_ENDPOINT_URL=http://localhost:9000
# For production AWS S3, leave S3_ENDPOINT_URL unset
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET_NAME=grins-platform-files
S3_REGION=us-east-1
# S3_ENDPOINT_URL=http://localhost:9000

# -----------------------------------------------------------------------------
# Plaid (banking integration for expense auto-import)
# -----------------------------------------------------------------------------
# Environments: sandbox (dev), production (live)
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-secret
PLAID_ENV=sandbox

# -----------------------------------------------------------------------------
# Vapi (voice AI webhook)
# -----------------------------------------------------------------------------
VAPI_API_KEY=your-vapi-api-key
VAPI_WEBHOOK_SECRET=your-vapi-webhook-secret

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,https://your-domain.com
