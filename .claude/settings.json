{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "statusLine": {
    "type": "command",
    "command": "bash .claude/statusline.sh"
  },
  "hooks": {
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/precompact-dump.sh",
            "timeout": 10,
            "statusMessage": "Dumping session state before compact..."
          }
        ]
      }
    ]
  }
}
