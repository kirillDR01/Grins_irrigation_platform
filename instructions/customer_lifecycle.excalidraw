    {
      "type": "text",
      "id": "r_queue_text",
      "x": 1030,
      "y": 3464,
      "width": 380,
      "height": 132,
      "text": "Reschedule request created\n→ appears in Reschedule Requests queue\n→ customer's alt-time reply captured in\n    requested_alternatives JSONB (appended)\n→ admin reviews, picks new date/time\n    (\"Reschedule to Alternative\" button)\n→ new confirmation SMS (#1) sent on save;\n    cycle repeats",
      "originalText": "Reschedule request created\n→ appears in Reschedule Requests queue\n→ customer's alt-time reply captured in\n    requested_alternatives JSONB (appended)\n→ admin reviews, picks new date/time\n    (\"Reschedule to Alternative\" button)\n→ new confirmation SMS (#1) sent on save;\n    cycle repeats",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "middle",
      "strokeColor": "#1e3a8a",
      "backgroundColor": "transparent",
