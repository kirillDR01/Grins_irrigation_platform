    {
      "type": "text",
      "id": "c_sms_text",
      "x": 2290,
      "y": 3224,
      "width": 380,
      "height": 100,
      "text": "[SYSTEM → CUSTOMER]\n\"Your [service type] appointment\non [date] at [time] has been cancelled.\nIf you'd like to reschedule, please\ncall us at [business phone].\"",
